# =============================================================================
# Dockerfile.gpu — VNAAS Grinder Server (GPU + CPU)
#
# CUDA 12.2 base + Node.js 20 + GPU binary + rana binary.
# Requires nvidia-docker runtime (--gpus all) to access the GPU.
#
# Build:
#   docker build -f docker/Dockerfile.gpu -t vnaas-grinder:gpu .
#
# Run:
#   docker run --gpus all --env-file server/.env vnaas-grinder:gpu
# =============================================================================

FROM nvidia/cuda:12.2.0-devel-ubuntu22.04 AS gpu-base

# Avoid interactive prompts during apt-get
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    pkg-config \
    libssl-dev \
    ca-certificates \
    curl \
    cmake \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20 via NodeSource
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# Stage 1: Build the GPU CUDA backend
# -----------------------------------------------------------------------------
FROM gpu-base AS gpu-builder

WORKDIR /app/gpu

# Copy GPU source
COPY server/gpu/ ./

# Build the CUDA offset grinding binary
RUN mkdir -p build && cd build && \
    cmake .. -DCMAKE_CUDA_ARCHITECTURES=80 && \
    make -j$(nproc)

# -----------------------------------------------------------------------------
# Stage 2: Build the TypeScript server
# -----------------------------------------------------------------------------
FROM gpu-base AS server-builder

WORKDIR /app/server

# Copy package files first for layer caching
COPY server/package.json server/package-lock.json* ./
RUN npm ci

# Copy server source and build
COPY server/tsconfig.json ./
COPY server/src/ ./src/
RUN npm run build

# -----------------------------------------------------------------------------
# Stage 3: Production image
# -----------------------------------------------------------------------------
FROM gpu-base AS production

WORKDIR /app/server

# Copy built server
COPY --from=server-builder /app/server/dist ./dist
COPY --from=server-builder /app/server/node_modules ./node_modules
COPY server/package.json ./

# Copy GPU binary from builder
COPY --from=gpu-builder /app/gpu/build/cuda_vanity_offset ./bin/cuda_vanity_offset
RUN chmod +x ./bin/cuda_vanity_offset

# Copy rana binary (pre-built for linux/amd64)
COPY server/bin/rana ./bin/rana
RUN chmod +x ./bin/rana

# Default environment
ENV VNAAS_RANA_BINARY_PATH=/app/server/bin/rana
ENV VNAAS_GPU_BINARY_PATH=/app/server/bin/cuda_vanity_offset
ENV VNAAS_ENABLE_GPU=true
ENV VNAAS_ENABLE_RANA=true
ENV VNAAS_ENABLE_BROWSER_FALLBACK=true
ENV VNAAS_ENABLE_PAYMENTS=false
ENV VNAAS_LN_BACKEND=none
ENV VNAAS_CASHU_MINT_URL=https://mint.minibits.cash
ENV VNAAS_FREE_THRESHOLD=8
ENV VNAAS_SATS_PER_BIT=10
ENV VNAAS_RELAYS=wss://relay.damus.io,wss://nos.lol
ENV NODE_ENV=production

# Expose optional HTTP health endpoint
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD node -e "fetch('http://localhost:3000/health').then(r=>r.ok?process.exit(0):process.exit(1)).catch(()=>process.exit(1))"

CMD ["node", "dist/index.js"]