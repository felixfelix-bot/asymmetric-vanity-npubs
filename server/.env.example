# =============================================================================
# VNAAS Grinder Server — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All environment variables use the VNAAS_ prefix.
# =============================================================================

# -----------------------------------------------------------------------------
# Nostr Server Identity (REQUIRED)
# -----------------------------------------------------------------------------

# Server's Nostr private key (hex-encoded). Generate one with:
#   node -e "const {generateSecretKey} = require('nostr-tools/pure'); console.log(Buffer.from(generateSecretKey()).toString('hex'))"
# Or use any Nostr key generation tool. This is the server's identity — NOT a
# user funds key. It's used for NIP-04 encrypted DM communication with clients.
VNAAS_SERVER_PRIVATE_KEY=

# Server's npub (derived from the private key above). Optional — the server
# will compute this at startup if left empty. Set it manually if you want
# to display it in config before startup.
VNAAS_SERVER_NPUB=

# -----------------------------------------------------------------------------
# Nostr Relays
# -----------------------------------------------------------------------------

# Comma-separated list of Nostr relay URLs the server will listen on for
# incoming MCP grind_npub requests (NIP-04 encrypted DMs).
VNAAS_RELAYS=wss://relay.damus.io,wss://nos.lol

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------

# Path to the rana binary (Rust CPU grinding backend).
# If the binary is in PATH, just use "rana".
# In Docker: /app/server/bin/rana
VNAAS_RANA_BINARY_PATH=./bin/rana

# Path to the cuda_vanity_offset binary (GPU CUDA grinding backend).
# If the binary is in PATH, just use "cuda_vanity_offset".
# In Docker (GPU image): /app/server/bin/cuda_vanity_offset
VNAAS_GPU_BINARY_PATH=./bin/cuda_vanity_offset

# Enable/disable backends (true/false). The server auto-detects at runtime
# and re-checks every 60 seconds. These flags control whether detection
# is attempted at all.
VNAAS_ENABLE_GPU=true
VNAAS_ENABLE_RANA=true

# Browser fallback is always enabled — when no server-side backend is
# available, the server returns instructions for client-side grinding.
VNAAS_ENABLE_BROWSER_FALLBACK=true

# -----------------------------------------------------------------------------
# Payment Configuration
# -----------------------------------------------------------------------------

# Enable payment processing for paid grinding (true/false).
# When false, all grinding is free. When true, patterns above the free
# threshold require payment via Cashu or Lightning.
VNAAS_ENABLE_PAYMENTS=false

# Cashu mint URL for ecash token verification.
# Popular mints:
#   https://mint.minibits.cash
#   https://nut.cashu.space
#   https://mint.nut.cash
VNAAS_CASHU_MINT_URL=https://mint.minibits.cash

# Lightning backend type: "lnd", "lnurl", or "none".
# When "none", Lightning payments are disabled and only Cashu is used.
# "lnd": requires LND node REST API (set VNAAS_LN_NODE_URL)
# "lnurl": requires LNURL-pay endpoint (set VNAAS_LN_NODE_URL)
VNAAS_LN_BACKEND=none

# URL for the Lightning node / LNURL endpoint (when backend is not "none").
# For LND: https://your-lnd-node:8080
# For LNURL: https://your-lnurl-pay-endpoint
VNAAS_LN_NODE_URL=

# -----------------------------------------------------------------------------
# Pricing Configuration
# -----------------------------------------------------------------------------

# Difficulty threshold (in bits) below which grinding is free.
# Each bech32 character = 5 bits of search space.
# Default: 8 bits (~256 keys, trivial patterns like 1-char prefix)
VNAAS_FREE_THRESHOLD=8

# Sats per bit of difficulty above the free threshold.
# Example: 15-bit pattern with threshold 8 → (15-8) * 10 = 70 sats
VNAAS_SATS_PER_BIT=10

# Minimum price in sats (for paid grinds above the free threshold).
VNAAS_MIN_PRICE_SATS=21

# Maximum price in sats (cap for very long patterns).
VNAAS_MAX_PRICE_SATS=10000

# -----------------------------------------------------------------------------
# Server / Operations
# -----------------------------------------------------------------------------

# Log level: "debug", "info", "warn", "error"
VNAAS_LOG_LEVEL=info

# Optional HTTP health endpoint port. The primary transport is Nostr
# (NIP-04 DMs), but a simple HTTP /health endpoint can run alongside
# for monitoring / container health checks.
VNAAS_PORT=3000